# Cloudflare Workers local secrets
# Copy to .dev.vars for `npm run cf:dev`

# Optional service-side trading wallet
# POLYMARKET_PRIVATE_KEY=0x...
# POLYMARKET_FUNDER_ADDRESS=0x...

# Optional command policy
# POLYGATE_DISABLED_COMMANDS=clob.createOrder,clob.cancelAll
# POLYGATE_FORCE_AUTH_COMMANDS=markets.list,events.list
# POLYGATE_REQUIRE_API_TOKEN_FOR_PRIVATE=true
# POLYGATE_API_TOKENS=token-dev-1,token-prod-2
# POLYGATE_API_TOKEN_HEADER=x-polygate-token

# Optional event delivery
# POLYGATE_WEBHOOK_URL=https://example.com/polygate/events
# POLYGATE_WEBHOOK_BEARER_TOKEN=your_token
# POLYGATE_WEBHOOK_TIMEOUT_MS=5000
# POLYGATE_SSE_HEARTBEAT_MS=15000
