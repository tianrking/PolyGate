HOST=0.0.0.0
PORT=3107
LOG_LEVEL=info
APP_CORS_ORIGIN=*
REQUEST_TIMEOUT_MS=8000
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute

POLYMARKET_CHAIN_ID=137
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com/
POLYMARKET_DATA_HOST=https://data-api.polymarket.com/
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_RPC_URL=https://polygon.drpc.org

# Server-side wallet mode
# POLYMARKET_PRIVATE_KEY=0x...
# POLYMARKET_FUNDER_ADDRESS=0x...
POLYMARKET_SIGNATURE_TYPE=proxy

# Keep false unless you fully trust callers and the network path to this service.
POLYMARKET_ALLOW_PRIVATE_KEY_OVERRIDE=false
POLYMARKET_API_KEY_CACHE_TTL_MS=300000

# Optional command policy
# Comma-separated command names, e.g. "clob.createOrder,clob.cancelAll"
POLYGATE_DISABLED_COMMANDS=
POLYGATE_FORCE_AUTH_COMMANDS=
POLYGATE_REQUIRE_API_TOKEN_FOR_PRIVATE=true
# Comma-separated API tokens for private commands.
# Example: POLYGATE_API_TOKENS=token-dev-1,token-prod-2
POLYGATE_API_TOKENS=
POLYGATE_API_TOKEN_HEADER=x-polygate-token

# Optional event delivery
# POLYGATE_WEBHOOK_URL=https://example.com/polygate/events
# POLYGATE_WEBHOOK_BEARER_TOKEN=your_token
POLYGATE_WEBHOOK_TIMEOUT_MS=5000
POLYGATE_SSE_HEARTBEAT_MS=15000
